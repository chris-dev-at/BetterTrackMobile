<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Dark-only app theme. Uses a platform Material parent (no support-library
      dependency) purely as a window/system-bar host; all real UI styling is done
      in Compose (BetterTrackTheme). Edge-to-edge is enabled in code with dark
      system bars.
    -->
    <style name="Theme.BetterTrack" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bt_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!--
      Android 12+ SplashScreen (compat back to minSdk 28): BT glyph on the
      near-black page background (§3.1 — the BT glyph as splash brand mark).
    -->
    <style name="Theme.BetterTrack.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bt_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_bt_glyph</item>
        <item name="postSplashScreenTheme">@style/Theme.BetterTrack</item>
    </style>
</resources>
