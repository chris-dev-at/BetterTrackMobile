<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- OAuth token exchange, /auth/me, and all future API calls. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
      Step 16 (§6.11): Android 13+ runtime notification permission. It is
      requested IN CONTEXT (from notification settings / the inbox prompt) — never
      on cold first launch — so no auto-prompt appears at install time.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Step 17 (§5): local app lock. USE_BIOMETRIC (API 28+) lets BiometricPrompt
      offer fingerprint/face unlock as the convenience path over the local PIN.
      The PIN itself is Keystore-hashed on-device; this is separate from the
      phone's own lockscreen and from the user's web-app PIN.
    -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!--
      REQUEST_INSTALL_PACKAGES is NOT here: it is the self-update permission and
      lives ONLY in the `github` flavor (app/src/github/AndroidManifest.xml). Play
      builds must not declare it (Device-and-Network-Abuse policy forbids
      self-update), so it stays out of the shared main manifest.

      AD_ID: the app has no ads and no analytics SDK, and the Data Safety form says
      so. If Firebase (or any transitive dependency) injects the advertising-ID
      permission, strip it from the merged manifest of every flavor.
    -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

    <!--
      Package visibility (Android 11+): we open the OAuth authorize page in a
      Chrome Custom Tab and the web "Need an account?/Forgot password?" links in
      a browser, so we must be able to see browser apps + the Custom Tabs service.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

    <application
        android:name=".BetterTrackApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BetterTrack"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.BetterTrack.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              OAuth 2.0 redirect deep link (§4): bettertrack://oauth/callback.
              singleTask above means a warm callback lands in onNewIntent and a
              cold callback in onCreate — both handled; the shell never stacks.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="${oauthRedirectScheme}"
                    android:host="oauth"
                    android:path="/callback" />
            </intent-filter>
        </activity>

        <!--
          Step 16 (§6.11): Firebase Cloud Messaging entry point. onMessageReceived
          posts to a channel + the in-app inbox; onNewToken hands the token to the
          (stubbed) device-token register. Real end-to-end push delivery is
          platform-gated (server FCM sender + device-token endpoint).
        -->
        <service
            android:name=".data.push.BtMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.messaging.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!--
          Dev in-app update (owner ask 2026-07-12): receives the PackageInstaller
          session callbacks (pending-user-action → launch the confirm sheet;
          success/failure → cleanup/retry). Explicit + not exported: only our own
          committed session's PendingIntent can trigger it.
        -->
        <receiver
            android:name=".data.update.UpdateInstallReceiver"
            android:exported="false" />

        <!-- FCM defaults for notifications posted by the system (background data). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_bt" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/bt_gold" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="bt_general" />

        <!--
          Step 18 (§6.12): per-app language (EN/DE). appcompat's autoStoreLocales
          service persists the AppCompatDelegate application-locale on API < 33 and
          re-applies it on process start; on API 33+ the framework LocaleManager
          owns persistence and this service no-ops. Enables the in-app language
          switch to survive restarts on every supported API level.
        -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>
